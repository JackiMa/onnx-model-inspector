{
  "name": "onnx-model-inspector",
  "displayName": "ONNX Model Inspector",
  "description": "Open ONNX, PT, and PTH model files in a self-contained graph, metadata, and tensor inspector for VS Code and Cursor.",
  "version": "0.6.0",
  "publisher": "gema",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JackiMa/onnx-model-inspector"
  },
  "homepage": "https://github.com/JackiMa/onnx-model-inspector#readme",
  "bugs": {
    "url": "https://github.com/JackiMa/onnx-model-inspector/issues"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "onnx",
    "metadata",
    "graph",
    "model",
    "inspector",
    "machine-learning",
    "deep-learning",
    "neural-network",
    "netron",
    "tensor"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "icon": "images/icon.png",
  "main": "./extension.js",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "configuration": {
      "title": "ONNX Model Inspector",
      "properties": {
        "onnxInspector.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable used for PT/PTH checkpoint inspection. Leave empty to use ONNX_INSPECTOR_PYTHON, CONDA_PYTHON_EXE, py -3 (Windows), or python3."
        },
        "onnxInspector.allowFullPickleLoad": {
          "type": "boolean",
          "default": false,
          "description": "Permit unsafe torch.load(weights_only=False) after explicit user consent. Disabled by default to prevent arbitrary code execution from malicious checkpoints. Still requires the workspace to be trusted."
        }
      }
    },
    "commands": [
      {
        "command": "onnxInspector.openFile",
        "title": "ONNX Inspector: Open File"
      },
      {
        "command": "onnxInspector.resetLoadConsent",
        "title": "ONNX Inspector: Reset Load Consent"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "onnxInspector.openFile",
          "when": "resourceExtname == .onnx || resourceExtname == .pt || resourceExtname == .pth || resourceExtname == .safetensors",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "onnxInspector.openFile",
          "when": "resourceExtname == .onnx || resourceExtname == .pt || resourceExtname == .pth || resourceExtname == .safetensors",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "onnxInspector.viewer",
        "displayName": "ONNX Model Inspector",
        "selector": [
          {
            "filenamePattern": "*.onnx"
          },
          {
            "filenamePattern": "*.pt"
          },
          {
            "filenamePattern": "*.pth"
          },
          {
            "filenamePattern": "*.safetensors"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "test": "node ./test/run-tests.cjs",
    "package:vsix": "python3 ./scripts/package_vsix.py",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish",
    "ovsx:publish": "ovsx publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.0",
    "ovsx": "^0.9.0"
  }
}
